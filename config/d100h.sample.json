{
  "version": 1,
  "device": {
    "displayName": "Ulanzi Studio D100H",
    "vendorId": null,
    "productId": null,
    "notes": "Driverless version: uses the standard input events Windows receives from the D100H."
  },
  "behavior": {
    "suppressOriginalInput": true,
    "exactModifierMatch": true,
    "debounceMs": 10,
    "defaultLayer": "default"
  },
  "startup": {
    "enabled": false,
    "startMinimized": true
  },
  "hid": {
    "applyOnStart": false,
    "applyMappingsFromUi": true,
    "selector": {
      "devicePath": null,
      "vendorId": null,
      "productId": null,
      "usagePage": null,
      "usage": null,
      "productContains": "Ulanzi"
    },
    "reports": [],
    "mappingTemplates": []
  },
  "bindings": {
    "default": {
      "dialClockwise": {
        "source": "VolumeUp",
        "mouse": {
          "wheel": "up",
          "clicks": 1
        },
        "description": "Dial clockwise"
      },
      "dialCounterClockwise": {
        "source": "VolumeDown",
        "mouse": {
          "wheel": "down",
          "clicks": 1
        },
        "description": "Dial counter-clockwise"
      },
      "dialPress": {
        "source": "VolumeMute",
        "layer": {
          "mode": "toggle",
          "target": "knobPressed",
          "fallback": "default"
        },
        "description": "Dial press: toggle the second layer"
      },
      "keyTopLeft": {
        "source": "MediaPreviousTrack",
        "send": "Ctrl+Z",
        "description": "Top left button"
      },
      "keyTopMiddle": {
        "source": "MediaPlayPause",
        "send": "Space",
        "description": "Top middle button"
      },
      "keyTopRight": {
        "source": "MediaNextTrack",
        "send": "Ctrl+Y",
        "description": "Top right button"
      },
      "keySideLeftTop": {
        "source": "Ctrl+V",
        "send": "Ctrl+V",
        "description": "Side left top button"
      },
      "keySideLeftBottom": {
        "source": "Ctrl+C",
        "send": "Ctrl+C",
        "description": "Side left bottom button"
      },
      "keySideRightTop": {
        "source": "Ctrl+Y",
        "send": "Ctrl+Shift+Z",
        "description": "Side right top button"
      },
      "keySideRightBottom": {
        "source": "Ctrl+Z",
        "send": "Ctrl+Z",
        "description": "Side right bottom button"
      }
    },
    "knobPressed": {
      "dialClockwise": {
        "source": "VolumeUp",
        "mouse": {
          "wheel": "right",
          "clicks": 1
        },
        "description": "Second layer dial clockwise"
      },
      "dialCounterClockwise": {
        "source": "VolumeDown",
        "mouse": {
          "wheel": "left",
          "clicks": 1
        },
        "description": "Second layer dial counter-clockwise"
      },
      "dialPress": {
        "source": "VolumeMute",
        "layer": {
          "mode": "toggle",
          "target": "knobPressed",
          "fallback": "default"
        },
        "description": "Dial press: return to the default layer"
      },
      "keyTopLeft": {
        "source": "MediaPreviousTrack",
        "send": "Shift+R",
        "description": "Layer 2 top left button"
      },
      "keyTopMiddle": {
        "source": "MediaPlayPause",
        "send": "Delete",
        "description": "Layer 2 top middle button"
      },
      "keyTopRight": {
        "source": "MediaNextTrack",
        "send": "G",
        "description": "Layer 2 top right button"
      },
      "keySideLeftTop": {
        "source": "Ctrl+V",
        "send": "Ctrl+NumpadAdd",
        "description": "Layer 2 zoom in"
      },
      "keySideLeftBottom": {
        "source": "Ctrl+C",
        "send": "Ctrl+NumpadSubtract",
        "description": "Layer 2 zoom out"
      },
      "keySideRightTop": {
        "source": "Ctrl+Y",
        "send": "Ctrl+Shift+Z",
        "description": "Layer 2 redo"
      },
      "keySideRightBottom": {
        "source": "Ctrl+Z",
        "send": "Ctrl+Z",
        "description": "Layer 2 undo"
      }
    }
  }
}
